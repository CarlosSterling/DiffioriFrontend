# ----------  FRONTEND (Next.js)  ----------
# URL que usará el NAVEGADOR para llamar a la API
# En producción real: NEXT_PUBLIC_API_URL=https://138.117.84.187:8080/api
# En local: usar ruta relativa para que pase por Nginx
NEXT_PUBLIC_API_URL=/api

# URL canónica de tu sitio (útil para SEO / OpenGraph)
# En producción real: NEXT_PUBLIC_SITE_URL=https://vivatech.com.co
NEXT_PUBLIC_SITE_URL=http://localhost:8080
